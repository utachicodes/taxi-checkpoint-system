# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Configuration
DATABASE_PATH=db.sqlite3
MEDIA_PATH=media

# AI Vision API Configuration
# The system uses Google Gemini API for vision-based license plate recognition
# Get your API key from: https://aistudio.google.com/apikey

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# TaxiGuard Integration: Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# External System IDs (from your Supabase database)
EXTERNAL_CHECKPOINT_ID=uuid-of-checkpoint-record
EXTERNAL_OPERATOR_ID=uuid-of-operator-record

# Canary Configuration (for health checks)
CANARY_ENABLED=true
CANARY_HEADER_NAME=X-Canary-Request
CANARY_HEADER_VALUE=random-string-not-known-outside
CANARY_INTERVAL=900
