# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Configuration
DATABASE_PATH=db.sqlite3
MEDIA_PATH=media

# AI Vision API Configuration
# The system uses OpenRouter for vision AI when OPENROUTER_API_KEY is set
# Get your API key from: https://openrouter.ai/keys

# PRIMARY: OpenRouter Configuration (Recommended)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_X_TITLE=TaxiGuard Vision

# Model to use (Qwen or other vision models available on OpenRouter)
QWEN_MODEL=qwen/qwen-2-vl-7b-instruct

# FALLBACK: Direct Qwen/Ollama Configuration (if not using OpenRouter)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://ollama.computedsynergy.com/v1

# TaxiGuard Integration: Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# External System IDs (from your Supabase database)
EXTERNAL_CHECKPOINT_ID=uuid-of-checkpoint-record
EXTERNAL_OPERATOR_ID=uuid-of-operator-record

# Canary Configuration (for health checks)
CANARY_ENABLED=true
CANARY_HEADER_NAME=X-Canary-Request
CANARY_HEADER_VALUE=random-string-not-known-outside
CANARY_INTERVAL=900
